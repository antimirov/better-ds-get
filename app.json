{
  "expo": {
    "name": "Better DS Get",
    "slug": "better-ds-get",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.antimirov.betterdsget"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.antimirov.betterdsget",
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_DATA_SYNC"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "magnet"
            },
            {
              "scheme": "synodownload"
            },
            {
              "scheme": "synodownloads"
            }
          ]
        },
        {
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "mimeType": "application/x-bittorrent",
              "scheme": "http",
              "host": "*"
            },
            {
              "mimeType": "application/x-bittorrent",
              "scheme": "https",
              "host": "*"
            },
            {
              "mimeType": "application/x-bittorrent",
              "scheme": "file"
            },
            {
              "mimeType": "application/x-bittorrent",
              "scheme": "content"
            },
            {
              "mimeType": "application/octet-stream",
              "scheme": "file"
            },
            {
              "mimeType": "application/octet-stream",
              "scheme": "content"
            }
          ]
        },
        {
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "pathPattern": ".*\\\\.torrent",
              "scheme": "http",
              "host": "*"
            },
            {
              "pathPattern": ".*\\\\.torrent",
              "scheme": "https",
              "host": "*"
            },
            {
              "pathPattern": ".*\\\\.torrent",
              "scheme": "file"
            },
            {
              "pathPattern": ".*\\\\.torrent",
              "scheme": "content"
            }
          ]
        }
      ]
    },
    "extra": {
      "eas": {
        "projectId": "2470788f-f8a8-41c8-bfb0-26c12fe90b0a"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00A1E4"
        }
      ],
      "./plugins/withNetworkSecurityConfig.js",
      "./plugins/withTorrentFileHandler.js",
      "./plugins/withNotifeeForegroundService.js",
      "expo-background-task"
    ]
  }
}
